PORT=5000
NODE_ENV=development

# MongoDB Configuration
# Para desenvolvimento local, use:
# MONGODB_URI=mongodb://localhost:27017/escola

# Para MongoDB Atlas (nuvem), use:
MONGODB_URI=mongodb+srv://SEU_USUARIO:SUA_SENHA@cluster.mongodb.net/escola?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=seu_secret_super_seguro_desenvolvimento
JWT_EXPIRE=30d

# Server Configuration
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Configurações da Aplicação
MAX_ALUNOS_POR_TURMA=35
ANO_LETIVO_ATUAL=2026
NUMERO_TRIMESTRES=3
